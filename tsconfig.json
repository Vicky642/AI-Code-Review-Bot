{
  "compilerOptions": {
    // Output
    "rootDir": "./",
    "outDir": "./dist",

    // Module system — CommonJS for Node.js GitHub Actions + @vercel/ncc bundling
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "es2020",
    "lib": ["es2020"],
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,

    // Strict checks (keep these, they're good)
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "action/**/*.ts",
    "engine/**/*.ts",
    "providers/**/*.ts",
    "rules/**/*.ts",
    "security/**/*.ts",
    "analytics/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dashboard/**"
  ]
}
